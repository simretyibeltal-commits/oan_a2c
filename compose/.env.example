# ERPNext Docker Compose Environment Variables
# Copy this file to .env and fill in your actual values

# Database Credentials
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MARIADB_ROOT_PASSWORD=your_mariadb_root_password_here

# Site Admin Passwords
SITE_ADMIN_PASSWORD_OAN_A2C=your_admin_password_for_oan_a2c

# AWS ECR Image
ECR_IMAGE=<AWS ID>.dkr.ecr.ap-south-1.amazonaws.com/oan_a2c:latest

# Redis Configuration
REDIS_CACHE_HOST=redis-cache:6379
REDIS_QUEUE_HOST=redis-queue:6379

# Database Configuration
DB_HOST=db
DB_PORT=3306

# Socket.io Configuration
SOCKETIO_PORT=9000

# Nginx Configuration
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# Site Names
SITE_NAME=<dns_name_of_your_site_here>
#SITE_NAME_VENTURES=erp.casavaventures.com

# Host Names (for bench set-config)
HOST_NAME=<fully qualifieed domanin name of your site here>
