    "item": [
        {
            "name": "Authentication & IAM",
            "item": [
                {
                    "name": "1. Login (Generate JWT)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"usr\": \"agent.ethiopia@coopbank.com\",\n    \"pwd\": \"SuperSecurePassword123!\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.auth.login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.auth.login"
                            ]
                        },
                        "description": "Authenticates the user using standard Frappe credentials and returns a short-lived JSON Web Token (JWT) intended for frontend stateless session management."
                    },
                    "response": []
                },
                {
                    "name": "2. Forgot Password Request",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"agent.ethiopia@coopbank.com\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.auth.forgot_password",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.auth.forgot_password"
                            ]
                        },
                        "description": "Triggers an email to the user with a reset password link containing a temporary cryptographic key."
                    },
                    "response": []
                },
                {
                    "name": "3. Reset Password (Bridge)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"agent.ethiopia@coopbank.com\",\n    \"key\": \"{{reset_key_from_email}}\",\n    \"new_password\": \"NewSuperSecurePassword987!\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.auth.reset_password",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.auth.reset_password"
                            ]
                        },
                        "description": "Sets a new password using the temporary key. Expected to be called by the Headless Frontend after a user clicks the reset link in their email."
                    },
                    "response": []
                }
            ]
        },
