        {
            "name": "System Webhooks (Requires API Key/Secret)",
            "item": [
                {
                    "name": "Inbound Telco Webhook (Idempotent Ingestion)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "token {{api_key}}:{{api_secret}}",
                                "type": "text",
                                "description": "Standard Frappe API Key and API Secret token."
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"phone_number\": \"+251911000003\",\n    \"lead_source\": \"Missed Call\",\n    \"external_ref_id\": \"TELCO-778899\",\n    \"timestamp\": \"2026-05-26T12:00:00Z\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.webhooks.lead_inbound",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.webhooks.lead_inbound"
                            ]
                        },
                        "description": "Automated ingestion callback for external telecommunication IVR / missed call nodes. Bypasses JWT gateway and authenticates system-to-system via API Token."
                    },
                    "response": []
                }
            ]
        },
