                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"action\": \"list\",\n    \"application_id\": \"{{application_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.loan_app_api.supporting_documents",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.loan_app_api.supporting_documents"
                            ]
                        }
                    }
                },
