                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lead_id\": \"{{lead_id}}\",\n  \"reason\": \"Farmer not interested anymore.\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.leads.reject_lead",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.leads.reject_lead"
                            ]
                        }
                    }
                },
                {
                    "name": "3.1 Submit Lead Details",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lead_id\": \"{{lead_id}}\",\n  \"loan_type\": \"Seed Loan\",\n  \"loan_amount\": 50000,\n  \"purpose_message\": \"Buy maize seeds\",\n  \"region\": \"Oromia\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.leads.submit_lead",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.leads.submit_lead"
                            ]
                        }
                    }
                },
                {
                    "name": "3.2 Schedule Visit",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lead_id\": \"{{lead_id}}\",\n  \"visit_date\": \"2026-12-01\",\n  \"notes\": \"Meet at farm\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.leads.schedule_visit",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.leads.schedule_visit"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "5. Loan Application Conversion",
            "item": [
                {
                    "name": "5.1 Create Loan from Lead",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var resp = pm.response.json();",
                                    "var msg  = resp.message || resp;",
                                    "if (msg.data && msg.data.application_id) { pm.collectionVariables.set('application_id', msg.data.application_id); }"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lead_id\": \"{{lead_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.loan_app_api.create_loan_from_lead",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.loan_app_api.create_loan_from_lead"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "6. Loan Application Processing",
            "item": [
                {
                    "name": "6.2 Supporting Documents - Upload",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "action",
                                    "value": "upload",
                                    "type": "text"
                                },
                                {
                                    "key": "application_id",
                                    "value": "{{application_id}}",
                                    "type": "text"
                                },
                                {
                                    "key": "document_type",
                                    "value": "Identity Document",
                                    "type": "text"
                                },
                                {
                                    "key": "file",
                                    "type": "file",
                                    "src": []
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.loan_app_api.supporting_documents",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.loan_app_api.supporting_documents"
                            ]
                        },
                        "description": "Uploads a file directly attached to a specific document type placeholder for the Loan Application."
                    }
                },
                {
                    "name": "6.2b Supporting Documents - List",
                    "request": {
                        "method": "POST",
                        "header": [
