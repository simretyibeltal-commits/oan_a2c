{
    "info": {
        "name": "OAN A2C \u2014 Full Collection Final Part 1",
        "description": "Logically ordered workflow for Access to Credit: Dashboards -> Lead Creation -> Consent -> Loan App Processing.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000",
            "type": "string"
        },
        {
            "key": "jwt_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "fayda_id",
            "value": "1234567890",
            "type": "string"
        },
        {
            "key": "partner",
            "value": "OAN Partner",
            "type": "string"
        },
        {
            "key": "lead_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "consent_request",
            "value": "",
            "type": "string"
        },
        {
            "key": "application_id",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "0. Authentication",
            "item": [
                {
                    "name": "0.1 Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var resp = pm.response.json();",
                                    "var token = (resp.message || {}).token || (resp.data || {}).token || '';",
                                    "if (token) { pm.collectionVariables.set('jwt_token', token); }"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"usr\": \"Administrator\",\n  \"pwd\": \"admin\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.auth.login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.auth.login"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "1. Dashboards",
            "item": [
                {
                    "name": "1.1 Lead Summary API",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.leads.get_lead_summary",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.leads.get_lead_summary"
                            ]
                        }
                    }
                },
                {
                    "name": "1.2 Lead List API",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"Open\",\n  \"page_length\": 20,\n  \"start\": 0\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.leads.get_leads",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.leads.get_leads"
                            ]
                        }
                    }
                },
                {
                    "name": "1.3 Loan Application Dashboard",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"page\": 1,\n  \"page_size\": 20,\n  \"status\": \"Draft\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.openagrinet_access_to_credit.doctype.loan_application.loan_application.get_loan_applications",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.openagrinet_access_to_credit.doctype.loan_application.loan_application.get_loan_applications"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Lead Generation",
            "item": [
                {
                    "name": "2.2 Create Lead (Missed Call/IVR Webhook)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var resp = pm.response.json();",
                                    "if (resp.message && resp.message.lead_id) { pm.collectionVariables.set('lead_id', resp.message.lead_id); }"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"phone_number\": \"0987654321\",\n  \"lead_source\": \"Missed Call\",\n  \"external_ref_id\": \"IVR-001\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.webhooks.lead_inbound",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.webhooks.lead_inbound"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "4. OpenG2P Consent Flow",
            "item": [
                {
                    "name": "4.1 Search Farmer",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"fayda_id\": \"{{fayda_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.consent.consent.search_farmer",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.consent.consent.search_farmer"
                            ]
                        }
                    }
                },
                {
                    "name": "4.2 Request OTP",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var resp = pm.response.json();",
                                    "var data = resp.data || {};",
                                    "if (data.consent_request) { pm.collectionVariables.set('consent_request', data.consent_request); }",
                                    "if (data.transaction_id) { pm.collectionVariables.set('transaction_id', data.transaction_id); }"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"fayda_id\": \"{{farmer_fayda_id}}\",\n  \"lead_id\": \"{{lead_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.consent.consent.request_otp",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.consent.consent.request_otp"
                            ]
                        }
                    }
                },
                {
                    "name": "4.3 Verify OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lead_id\": \"{{lead_id}}\",\n  \"consent_request\": \"{{consent_request}}\",\n  \"transaction_id\": \"{{transaction_id}}\",\n  \"otp_code\": \"111111\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.consent.consent.verify_otp",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.consent.consent.verify_otp"
                            ]
                        }
                    }
                },
                {
                    "name": "4.4 Submit Consent",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lead_id\": \"{{lead_id}}\",\n  \"consent_request\": \"{{consent_request}}\",\n  \"consent_type\": \"specific\",\n  \"consent_reason_id\": 1,\n  \"validity_from\": \"2026-06-01\",\n  \"validity_to\": \"2027-06-01\",\n  \"consent_form_filename\": \"signed_consent.txt\",\n  \"consent_form_base64\": \"VGhpcyBpcyBhIHNhbXBsZSBzaWduZWQgY29uc2VudCBmb3JtLg==\",\n  \"allowed_data_field_ids\": [1, 2]\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.consent.consent.submit_consent",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.consent.consent.submit_consent"
                            ]
                        }
                    }
                },
                {
                    "name": "4.5 Send Success Notification",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lead_id\": \"{{lead_id}}\",\n  \"message\": \"Your OTP has been successfully verified!\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/method/oan_a2c.api.v1.leads.send_notification",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "method",
                                "oan_a2c.api.v1.leads.send_notification"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Lead Qualification & Processing",
            "item": [
                {
                    "name": "3.3 Verify Lead",
                    "request": {
                        "method": "POST",
                        "header": [
