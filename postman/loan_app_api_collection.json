						"{{base_url}}"
					],
					"path": [
						"api",
						"method",
						"oan_a2c.api.loan_app_api.supporting_documents"
					]
				},
				"description": "Uploads a supporting document. Valid document_type values: 'Marriage Certificate', 'Identity Document', 'Land Ownership Proof'."
			},
			"response": []
		},
