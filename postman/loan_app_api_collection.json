					"mode": "raw",
					"raw": "{\n    \"action\": \"save\",\n    \"application_id\": \"{{application_id}}\",\n    \"bank_account_name\": \"John Doe\",\n    \"bank_account_number\": \"10002930291\",\n    \"bank_name\": \"Cooperative Bank\",\n    \"total_amount_borrowing\": 45000\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/method/oan_a2c.api.loan_app_api.bank_details",
