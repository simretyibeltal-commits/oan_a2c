		"name": "A2C Loan Application API",
		"description": "API Contracts for the Open Agri Loan Application workflow (Steps 1, 2, 3, 5, 6) secured under the oan_a2c JWT authorization space.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. Secure Login",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"usr\": \"test_agent@coopbank.com\",\n    \"pwd\": \"test_agent@1234\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/method/oan_a2c.api.loan_app_api.login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"method",
						"oan_a2c.api.loan_app_api.login"
					]
				},
				"description": "Authenticates the agent and issues a stateless JWT token."
			},
			"response": []
		},
		{
			"name": "1. Loan Details (Step 1)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"action\": \"save\",\n    \"loan_type\": \"Input Financing\",\n    \"purpose_of_loan\": \"Agro-processing\",\n    \"requested_loan_amount\": 45000,\n    \"loan_duration_months\": \"12 Months (1 Year)\",\n    \"nearest_branch\": \"Standard Branch\",\n    \"primary_crop\": \"Wheat\",\n    \"region\": \"Oromia\",\n    \"woreda\": \"Bishoftu\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/method/oan_a2c.api.loan_app_api.loan_details",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"method",
						"oan_a2c.api.loan_app_api.loan_details"
					]
				},
				"description": "Creates or updates the loan requirement details."
			},
			"response": []
		},
