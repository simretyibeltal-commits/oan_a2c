{
	"info": {
		"name": "OAN A2C Consent API",
		"description": "API Contracts specifically for the OpenG2P Consent Management lifecycle in A2C.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Search Farmer",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"fayda_id\": \"FAYDA-123\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/method/oan_a2c.api.v1.consent.consent.search_farmer",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"method",
						"oan_a2c.api.v1.consent.consent.search_farmer"
					]
				}
			}
		},
		{
			"name": "2. Request OTP",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"fayda_id\": \"FAYDA-123\",\n    \"partner\": \"Test Partner\",\n    \"lead_id\": \"{{lead_id}}\",\n    \"purpose\": \"Testing Consent API\",\n    \"validity_from\": \"2026-06-01 00:00:00\",\n    \"validity_to\": \"2027-06-01 00:00:00\",\n    \"consent_form_attachment\": \"/files/consent.pdf\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/method/oan_a2c.api.v1.consent.consent.request_otp",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"method",
						"oan_a2c.api.v1.consent.consent.request_otp"
					]
				}
			}
		},
		{
			"name": "3. Verify OTP and Approve Consent",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt_token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"lead_id\": \"{{lead_id}}\",\n    \"otp_code\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/method/oan_a2c.api.v1.consent.consent.verify_otp_for_lead",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"method",
						"oan_a2c.api.v1.consent.consent.verify_otp_for_lead"
					]
				}
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "jwt_token",
			"value": "PASTE_YOUR_TOKEN_HERE"
		},
		{
			"key": "lead_id",
			"value": "LEAD-YYYY-XXXXX"
		}
	]
}
